// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user") // user | admin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Profile fields (from invite request)
  designation          String?
  companyName          String?
  companyEmail         String?
  companyWebsite       String?
  phone                String?
  location             String?
  billingAddress       String?
  billingContactName   String?
  billingContactPhone  String?
  referralSource       String?
  referralDetail       String?

  projects    Project[]
  blogPosts   BlogPost[]

  @@index([email])
  @@map("users")
}

model Project {
  id           String    @id @default(uuid())
  name         String
  tonnage      Int?
  dateUpload    DateTime  @default(now())
  dateConfirmed DateTime?
  dateFinish    DateTime?
  datePayment   DateTime?
  cost         Float?
  currency     String   @default("USD") // "USD" | "INR"
  isPaidInitial Boolean  @default(false) // Track if initial submission has been paid
  downloadLink String?
  uploadLink   String?
  // Main project video (admin uploaded)
  videoUrl     String?
  uploadedBy   String?
  status       String    @default("waiting_for_confirmation") // waiting_for_confirmation | in_progress | issue | finished
  userId       String?
  notes        String?
  queueOrder   Int?     // User-defined queue priority (lower = higher priority)

  // Initial submission (original upload)
  userFileName String?
  userFileUrl  String?
  userFileSize Int?
  userFileType String?

  // Initial admin deliverable file
  adminFileName String?
  adminFileUrl  String?
  adminFileSize Int?
  adminFileType String?
  
  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  steps       ProjectStep[]

  @@index([userId])
  @@index([status])
  @@index([dateUpload])
  @@map("projects")
}

model ProjectStep {
  id          String    @id @default(uuid())
  projectId   String
  order       Int
  userLabel   String

  // User upload
  userFileName String?
  userFileUrl  String?
  userFileSize Int?
  userFileType String?

  // Admin deliverable
  adminFileName String?
  adminFileUrl  String?
  adminFileSize Int?
  adminFileType String?

  // Per-step cost/payment
  cost        Float?
  currency    String    @default("USD") // "USD" | "INR"
  isPaid      Boolean   @default(false)
  datePayment DateTime?

  createdAt   DateTime  @default(now())

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_steps")
}

model BlogPost {
  id          String    @id @default(uuid())
  slug        String    @unique
  title       String
  excerpt     String
  body        String    @db.Text
  coverImage  String
  category    String    @default("Engineering")
  status      String    @default("draft") // "draft" | "published"
  authorId    String?
  author      User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  @@index([slug])
  @@index([status])
  @@index([createdAt])
  @@map("blog_posts")
}

model OtpVerification {
  id          String   @id @default(uuid())
  email       String   @unique
  otp         String
  name        String
  companyName String
  website     String?

  // Extended invite fields
  designation          String?
  companyEmail         String?
  phone                String?
  location             String?
  billingAddress       String?
  billingContactName   String?
  billingContactPhone  String?
  referralSource       String?
  referralDetail       String?

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("otp_verifications")
}
